HOST=0.0.0.0
PORT=4000
API_DOMAIN=api.tatuzin.com.br
DATABASE_URL=postgresql://tatuzin_backend:change-me@db.example.com:5432/tatuzin_prod?schema=public
JWT_SECRET=change-me-with-at-least-16-characters
ACCESS_TOKEN_TTL=12h
REFRESH_TOKEN_TTL_DAYS=30
PASSWORD_RESET_TOKEN_TTL_MINUTES=30

CORS_ORIGINS=https://admin.tatuzin.com.br
TRUST_PROXY=1
APP_ENV=production

PLATFORM_JOB_SWEEP_INTERVAL_MS=300000
SESSION_CLEANUP_RETENTION_DAYS=30
RATE_LIMIT_BUCKET_RETENTION_MINUTES=1440

ALLOW_INITIAL_BOOTSTRAP=false

RESEND_API_KEY=re_change_me
MAIL_FROM_AUTH=Tatuzin <auth@mail.tatuzin.com.br>
MAIL_REPLY_TO_SUPPORT=suporte@tatuzin.com.br
PASSWORD_RESET_APP_BASE_URL=https://admin.tatuzin.com.br/reset-password
PASSWORD_RESET_DEBUG_LOG_TOKEN=false

RUN_DB_MIGRATIONS=true
