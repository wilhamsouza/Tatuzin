{
	servers {
		trusted_proxies static private_ranges
	}
}

http://127.0.0.1 {
	respond /healthz 200
}

{$API_DOMAIN} {
	encode gzip zstd

	log {
		output stdout
		format json
	}

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "no-referrer"
	}

	@api path /api/*
	handle @api {
		reverse_proxy backend:4000 {
			health_uri /api/readiness
			health_interval 30s
			health_timeout 5s
			transport http {
				dial_timeout 5s
				response_header_timeout 30s
				read_timeout 30s
				write_timeout 30s
			}
		}
	}

	handle {
		respond 404
	}
}
